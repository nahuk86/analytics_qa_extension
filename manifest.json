{
  "manifest_version": 3,
  "name": "Analytics QA Extension",
  "version": "1.0.0",
  "description": "Automated validation of Adobe Analytics hits against configurable contracts.",
  "permissions": [
    "webRequest",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://*.omtrdc.net/*",
    "http://*.omtrdc.net/*",
    "*://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "devtools_page": "devtools.html",
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Analytics QA Extension"
  }
}
